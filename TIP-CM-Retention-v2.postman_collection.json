{
  "info": {
    "name": "TIP CM Retention Lean MVP v2",
    "description": "Complete test collection for FDIC TIP CM Retention API.\n\nCovers:\n- Taxonomy (Categories & Sub-Categories)\n- Pattern A: Document Classification (US-1.13-Lean)\n- Pattern B: Table Registration & automatic trigger-based classification (US-1.24-Lean)\n- Audit Archive queries (US-1.Audit-Lean)\n- Error / edge-case scenarios\n\nSetup:\n1. Set collection variable `baseUrl` to your server (default: http://localhost:8080/tip/api)\n2. Set `bearerToken` to a valid Azure AD JWT with appropriate roles\n3. Run the folders in order: Taxonomy → Pattern A → Pattern B → Audit",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "tip-cm-retention-v2"
  },
  "variable": [
    { "key": "baseUrl",       "value": "http://localhost:8080/tip/api", "type": "string" },
    { "key": "bearerToken",   "value": "REPLACE_WITH_AZURE_AD_JWT",     "type": "string" },
    { "key": "categoryId",    "value": "", "type": "string" },
    { "key": "subCategoryId", "value": "", "type": "string" },
    { "key": "documentId",    "value": "", "type": "string" },
    { "key": "auditEventId",  "value": "", "type": "string" },
    { "key": "registrationId","value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{bearerToken}}", "type": "string" }]
  },
  "item": [

    {
      "name": "01 - Taxonomy",
      "description": "Browse retention Categories and Sub-Categories (read-only).",
      "item": [

        {
          "name": "01.01 List all Categories",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has content array', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('content');",
                  "  pm.expect(body.content).to.be.an('array').that.is.not.empty;",
                  "});",
                  "pm.test('First category has expected fields', () => {",
                  "  const cat = pm.response.json().content[0];",
                  "  pm.expect(cat).to.have.all.keys('id','code','name','active','createdAt','createdBy');",
                  "  pm.expect(cat.active).to.be.true;",
                  "});",
                  "// Store first category id for later tests",
                  "const first = pm.response.json().content[0];",
                  "pm.collectionVariables.set('categoryId', first.id);",
                  "pm.collectionVariables.set('testCategoryCode', first.code);",
                  "console.log('Stored categoryId:', first.id, 'code:', first.code);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/categories?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["v1","categories"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        },

        {
          "name": "01.02 Get Category by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Category ID matches', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.id).to.eql(pm.collectionVariables.get('categoryId'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/categories/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1","categories","{{categoryId}}"]
            }
          }
        },

        {
          "name": "01.03 Get Category by ID – Not Found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));",
                  "pm.test('Error body has status field', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql(404);",
                  "  pm.expect(body.error).to.eql('NOT_FOUND');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/categories/00000000-0000-0000-0000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["v1","categories","00000000-0000-0000-0000-000000000000"]
            }
          }
        },

        {
          "name": "01.04 List Sub-Categories (all)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has sub-category content', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.content).to.be.an('array').that.is.not.empty;",
                  "});",
                  "pm.test('Sub-category has duration fields', () => {",
                  "  const sc = pm.response.json().content[0];",
                  "  pm.expect(sc).to.have.property('retentionDurationValue');",
                  "  pm.expect(sc).to.have.property('retentionDurationUnit');",
                  "  pm.expect(['DAYS','MONTHS','YEARS']).to.include(sc.retentionDurationUnit);",
                  "});",
                  "// Store first sub-category for classify tests",
                  "const sc = pm.response.json().content[0];",
                  "pm.collectionVariables.set('subCategoryId', sc.id);",
                  "pm.collectionVariables.set('subCategoryCode', sc.code);",
                  "console.log('Stored subCategoryCode:', sc.code);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/sub-categories?page=0&size=50",
              "host": ["{{baseUrl}}"],
              "path": ["v1","sub-categories"],
