    {
      "name": "03 - Pattern B – Table Registration",
      "description": "US-1.24-Lean: Register upstream tables for automatic DB-trigger-based retention.\n\nAfter registration, TIP installs BEFORE + AFTER INSERT triggers on the upstream table.\nEvery INSERT then auto-computes eligibility_date with no per-row API call needed.",
      "item": [

        {
          "name": "03.01 Register Table – examination.findings",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Registration response has required fields', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('registrationId');",
                  "  pm.expect(body).to.have.property('triggerName');",
                  "  pm.expect(body.schemaName).to.eql('examination');",
                  "  pm.expect(body.tableName).to.eql('findings');",
                  "  pm.expect(body.basisDateColumn).to.eql('closed_date');",
                  "  pm.expect(body.defaultSubCategoryCode).to.eql('EXAM_FINDINGS_25Y');",
                  "  pm.collectionVariables.set('registrationId', body.registrationId);",
                  "  pm.collectionVariables.set('triggerName', body.triggerName);",
                  "  console.log('Trigger installed:', body.triggerName);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schemaName\": \"examination\",\n  \"tableName\": \"findings\",\n  \"basisDateColumn\": \"closed_date\",\n  \"defaultSubCategoryCode\": \"EXAM_FINDINGS_25Y\",\n  \"registeredBy\": \"jsmith\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/table-registrations",
              "host": ["{{baseUrl}}"],
              "path": ["v1","table-registrations"]
            }
          }
        },

        {
          "name": "03.02 Register Table – case_mgmt.cases",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('case_mgmt.cases registered', () => {",
