                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('content');",
                  "  pm.expect(body).to.have.property('totalElements');",
                  "  pm.expect(body.content).to.be.an('array');",
                  "});",
                  "pm.test('Audit event has required fields', () => {",
                  "  const body = pm.response.json();",
                  "  if (body.content.length > 0) {",
                  "    const e = body.content[0];",
                  "    pm.expect(e).to.have.property('id');",
                  "    pm.expect(e).to.have.property('eventType');",
                  "    pm.expect(e).to.have.property('classificationPattern');",
                  "    pm.expect(e).to.have.property('categoryCode');",
                  "    pm.expect(e).to.have.property('subCategoryCode');",
                  "    pm.expect(e).to.have.property('eligibilityDate');",
