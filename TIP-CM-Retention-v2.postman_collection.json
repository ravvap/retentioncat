    {
      "name": "02 - Pattern A – Document Classification",
      "description": "US-1.13-Lean: Classify documents into TIP retention via the REST API.\n\nFlow tested:\n1. Classify new document → 201\n2. Re-submit same sourceReference → 200 (idempotent)\n3. Classify with unknown sub-category → 422\n4. Classify with missing required fields → 400\n5. Retrieve by ID\n6. Search with filters",
      "item": [

        {
          "name": "02.01 Classify Document – New (201)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Generate a unique sourceReference per run so re-runs don't hit idempotency",
                  "const ref = 'EW-' + new Date().getTime();",
                  "pm.collectionVariables.set('sourceRef', ref);",
                  "console.log('Using sourceRef:', ref);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Response has retentionRecordId', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('retentionRecordId');",
                  "  pm.expect(body.retentionRecordId).to.be.a('string');",
                  "  pm.collectionVariables.set('documentId', body.retentionRecordId);",
                  "});",
                  "pm.test('eligibilityDate is basisDate + 25 years', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.eligibilityDate).to.eql('2051-05-29');",
                  "  pm.expect(body.retentionDurationValue).to.eql(25);",
                  "  pm.expect(body.retentionDurationUnit).to.eql('YEARS');",
                  "});",
                  "pm.test('auditEventId is populated', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.auditEventId).to.be.a('string');",
                  "  pm.collectionVariables.set('auditEventId', body.auditEventId);",
                  "});",
                  "pm.test('Category and sub-category populated', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.categoryCode).to.eql('EXAM_RECORDS');",
                  "  pm.expect(body.subCategoryCode).to.eql('EXAM_FINDINGS_25Y');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sourceReference\": \"{{sourceRef}}\",\n  \"sourceSystem\": \"examination_workflow\",\n  \"filename\": \"EW-finding-report.pdf\",\n  \"sizeBytes\": 204800,\n  \"subCategoryCode\": \"EXAM_FINDINGS_25Y\",\n  \"basisDate\": \"2026-05-29\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/documents",
              "host": ["{{baseUrl}}"],
              "path": ["v1","documents"]
            }
          }
        },

        {
          "name": "02.02 Classify Document – Idempotent Re-submit (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 (idempotent)', () => pm.response.to.have.status(200));",
                  "pm.test('Same retentionRecordId returned', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.retentionRecordId).to.eql(pm.collectionVariables.get('documentId'));",
                  "});",
                  "pm.test('auditEventId is null for idempotent hit', () => {",
