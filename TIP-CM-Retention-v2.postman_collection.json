          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/sub-categories?categoryCode=EXAM_RECORDS&page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["v1","sub-categories"],
              "query": [
                { "key": "categoryCode", "value": "EXAM_RECORDS" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
