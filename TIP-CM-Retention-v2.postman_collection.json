                "exec": [
                  "const yesterday = new Date(Date.now() - 86400000).toISOString();",
                  "const tomorrow  = new Date(Date.now() + 86400000).toISOString();",
                  "pm.collectionVariables.set('fromDate', yesterday);",
                  "pm.collectionVariables.set('toDate',   tomorrow);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Events within date range', () => {",
                  "  const body = pm.response.json();",
                  "  const from = new Date(pm.collectionVariables.get('fromDate'));",
                  "  const to   = new Date(pm.collectionVariables.get('toDate'));",
                  "  body.content.forEach(e => {",
                  "    const occurred = new Date(e.occurredAt);",
                  "    pm.expect(occurred >= from && occurred <= to).to.be.true;",
                  "  });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
